# Production Environment Configuration
# Copy this file to .env.production and update with your production values

# Database Configuration
PGUSER=yaltt
PGPASSWORD=your-secure-database-password-here
PGDATABASE=yaltt
PGPORT=5432

# Redis Configuration (optional password)
REDIS_PORT=6379
REDIS_PASSWORD=

# Application Configuration
YALTT_HOST=yaltt.paulgray.net
SSL=true
PORT=3000

# Admin Credentials - CHANGE THESE IN PRODUCTION
ADMIN_USER=admin
ADMIN_PASSWORD=your-secure-admin-password-here

# Google OAuth Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Session & JWT Secrets - MUST BE RANDOM STRINGS IN PRODUCTION
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-random-session-secret-here
JWT_SECRET=your-random-jwt-secret-here
